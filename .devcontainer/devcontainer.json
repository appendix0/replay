{
  "name": "RE:PLAY",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",

  // 1. Install deps
  // 2. Write .env.local from Codespaces secrets (if set), else copy the example
  "postCreateCommand": "npm install && bash .devcontainer/setup-env.sh",

  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "RE:PLAY dev server",
      "onAutoForward": "openBrowser"
    }
  },

  // Map GitHub Codespaces secrets → shell env vars inside the container
  "secrets": {
    "ANTHROPIC_API_KEY": {},
    "SUPABASE_URL": {},
    "SUPABASE_SERVICE_ROLE_KEY": {},
    "NEXT_PUBLIC_SUPABASE_URL": {},
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": {},
    "ELEVENLABS_API_KEY": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "typescript.tsdk": "node_modules/typescript/lib"
      }
    }
  }
}
